					type: "item"
				}
			]
			subtitle: "种子转化"
			tasks: [{
				id: "4EFDE2675BE92EDC"
				item: "agricraft:seed_analyzer"
				type: "item"
			}]
			title: "种子分析"
			x: 0.0d
			y: 2.0d
		}
		{
			dependencies: ["73AC29CE33479E8A"]
			description: [
				"除了常见的作物外，在世界上还隐藏有各种各样的特殊作物——这些作物绝大部分需要杂交获得，小部分则可以通过在世界中探索战利品获得。"
				""
				"装备&6绯红肋&r后，打开世界中的战利品箱，概率会获得&c远古作物&r种子。"
				""
				"远古作物本身如果用于种植，可以生产不同的血肉材料，但其更重要的便是用于更多种子的杂交。"
			]
			id: "16BC90547AAC6998"
			rewards: [{
				id: "474A2CB90C93C7DB"
				item: "lightmanscurrency:coin_gold"
				type: "item"
			}]
			subtitle: "追寻原初的呼唤"
			tasks: [{
				id: "770FBC2EF42161D4"
				item: {
					Count: 1
					id: "kubejs:crimson_rib"
					tag: { }
				}
				type: "item"
			}]
			x: 0.0d
			y: 4.0d
		}
		{
			dependencies: ["73AC29CE33479E8A"]
			description: [
				"相比于常规作物，在作物架上种植的特殊作物有着各异的生长要求——一般来说，这些生长条件都与其所能生长的&6土壤种类&r相关。"
				""
				"举例而言，&6稻米&r由于需求漫灌及以上的土壤水分要求，因此在其&6适应为1&r时（种子的最初状态），&6仅能够种植在水凝胶上&r。"
				""
				"但随着杂交使其抗性提升，在&6适应达到5&r时，&6稻米便可以种植在黏土上&r——这些信息您都可以通过对作物种子&6使用JEI预览&r到。"
				""
				"因此，土壤的选择虽然重要，但仍可以通过作物本身的培养来克服这些困难。"
			]
			id: "1CD0E619EF33D8D5"
			rewards: [{
				id: "3F807546179395AD"
				item: "lightmanscurrency:coin_gold"
				type: "item"
